/* Just to draw the red dots for transcript focus. Separated from everything else to allow it to run
 * at every scale to allow label flipping without stressing performance by doing the other
 * transcript drawing stuff.
 */

program "ensembl-webteam/core" "focus-transcript-dots" 1;
refer "libperegrine";
refer "libeoe";
include "../common/track-common.eard";
include "../common/track-style.eard";
include "gene-common-data.eard";
include "gene-common-visual.eard";

track_styles();

/* Get data */

let (focus_genome_id,focus_transcript_id) = focus_transcript_settings();

let req = request("self()","transcript");
scope(req,"id",focus_transcript_id);
scope(req,"genome",focus_genome_id);
scope(req,"type",["transcript"]);
let data = get_data(req);
let (*gene,*tr,*ex) = extract_tr_data(data);
halt(only_warm());

let on_this_stick = index(gene.stick,0) == stick();

let leaf_dots = if(on_this_stick,leaf("dots/content"),leaf(""));
let leaf_text = if(on_this_stick,leaf("tracks/flagtop/main"),leaf(""));

let **focus_tr = index(**tr,0);
let text_start = comma_format(focus_tr.start+1);
let text_end = comma_format(focus_tr.end);

red_dotted(focus_tr.start,focus_tr.end,text_start,text_end,leaf_dots,leaf_text);